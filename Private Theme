task.spawn(function()
    local imgui = game:GetService("CoreGui"):WaitForChild("imgui", 10)
    if not imgui then return end

    local RunService = game:GetService("RunService")

    -- 🎨 GLOBAL RAINBOW STORAGE
    local RAINBOW_COLOR = Color3.fromRGB(255, 255, 255)

    -- Listahan ng mga elements na sasayaw sa rainbow loop
    local rainbowElements = {}

    -- Isang loop para sa lahat ng elements para tipid sa FPS at swabe ang transition
    RunService.RenderStepped:Connect(function()
        local hue = (os.clock() % 5) / 5 -- Buong rainbow cycle kada 5 segundo
        RAINBOW_COLOR = Color3.fromHSV(hue, 0.8, 0.8) -- Vibrant rainbow color

        -- I-update ang lahat ng rehistradong elements
        for element, prop in pairs(rainbowElements) do
            if element and element.Parent then
                element[prop] = RAINBOW_COLOR
            else
                rainbowElements[element] = nil -- Auto-cleanup kapag nawala ang UI element
            end
        end
    end)

    -- Function para i-hook ang lahat ng UI elements sa rainbow loop
    local function makeEverythingRainbow(element)
        local nameLower = element.Name:lower()
        
        -- 🛠️ ELERIUM V2 FIXED FOLDER EXCLUSION (TRANSPARENT SYSTEM)
        local isFolderElement = nameLower:match("folder") or (element.Parent and element.Parent.Name:lower():match("folder"))
        if isFolderElement then
            -- Make backgrounds and images completely transparent
            if element:IsA("Frame") or element:IsA("TextButton") or element:IsA("TextBox") then
                element.BackgroundTransparency = 1
            elseif element:IsA("ImageLabel") or element:IsA("ImageButton") then
                element.ImageTransparency = 1
            end
            
            -- Keep text fully visible so you can still read the folder name and options
            if element:IsA("TextLabel") or element:IsA("TextButton") or element:IsA("TextBox") then
                element.TextTransparency = 0
                element.TextColor3 = Color3.fromRGB(255, 255, 255) -- Solid White text
            end
            return -- Immediately break to stop the loop from adding it to rainbow elements
        end

        -- EXCLUSION CRITERIA: Huwag galawin ang mismong toggles at checkmarks para magamit pa rin
        if nameLower:match("indicator") or nameLower:match("checkmark") or element.Name == "Toggle_2" or nameLower:match("toggle") then
            return 
        end

        -- 1. Para sa mga Frames, Buttons, at TextBoxes (Backgrounds, Bars, Tabs, Lines)
        if element:IsA("Frame") or element:IsA("TextButton") or element:IsA("TextBox") then
            rainbowElements[element] = "BackgroundColor3"
        
        -- 2. Para sa mga UI na gumagamit ng Images/Icons (Roundify, Image Backgrounds)
        elseif element:IsA("ImageLabel") or element:IsA("ImageButton") then
            rainbowElements[element] = "ImageColor3"
        
        -- 3. Para sa SelectionBox o Highlights
        elseif element:IsA("SelectionBox") then
            rainbowElements[element] = "Color3"
        elseif element:IsA("Highlight") then
            rainbowElements[element] = "FillColor"
            -- Isabay na rin ang Outline para rainbow lahat
            rainbowElements[element] = "OutlineColor" 
        end
        
        -- 4. Kulay ng mga Text (Gawing Puti at i-lock para nababasa sa ibabaw ng rainbow)
        if element:IsA("TextLabel") or element:IsA("TextButton") or element:IsA("TextBox") then
            if not element:GetAttribute("Text_Locked") then
                element.TextColor3 = Color3.fromRGB(255, 255, 255)
                element:SetAttribute("Text_Locked", true)
            end
        end
    end

    -- I-apply sa mga kasalukuyang elements
    for _, element in pairs(imgui:GetDescendants()) do
        task.defer(makeEverythingRainbow, element)
    end

    -- I-apply sa mga bagong pasok na dropdowns, tabs, o windows
    imgui.DescendantAdded:Connect(function(element)
        task.defer(makeEverythingRainbow, element)
    end)
end)
